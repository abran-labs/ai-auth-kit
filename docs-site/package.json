{
  "name": "ai-auth-kit-docs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "lint": "biome check .",
    "typecheck": "astro check && tsc --noEmit -p tsconfig.scripts.json",
    "check": "bun run lint && bun run typecheck",
    "test": "bun test",
    "qa:browser": "bun run tests/browser-qa.ts",
    "assets:social": "bun run scripts/render-social-card.ts",
    "validate:template": "bun run scripts/validate-template.ts source",
    "validate:dist": "bun run scripts/validate-template.ts dist"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.6.0",
    "@astrojs/starlight": "0.41.3",
    "@fontsource-variable/newsreader": "^5.2.8",
    "@fontsource-variable/public-sans": "^5.2.7",
    "@fontsource/fragment-mono": "^5.2.8",
    "astro": "^7.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "^2.3.8",
    "@types/bun": "^1.3.5",
    "playwright": "^1.57.0",
    "typescript": "^5.9.3"
  }
}
