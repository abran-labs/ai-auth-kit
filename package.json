{
  "name": "@abran-labs/ai-auth-kit",
  "version": "0.2.0",
  "description": "Reusable AI provider authentication and model selection kit for CLI tools.",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "license": "MIT",
  "private": false,
  "bin": {
    "ai-auth-kit": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "bun test",
    "test:types": "tsc -p tsconfig.test.json --noEmit",
    "audit:dependencies": "bun run scripts/audit-dependencies.ts",
    "qa:minimum-release-age": "bun run scripts/qa-minimum-release-age.ts",
    "dev": "bun run src/cli.ts"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.0.1",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "ai",
    "auth",
    "cli",
    "llm",
    "model-picker"
  ]
}
