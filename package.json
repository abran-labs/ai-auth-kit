{
  "name": "@abran-labs/ai-auth-kit",
  "version": "0.2.0",
  "description": "Reusable AI provider authentication and model selection kit for CLI tools.",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "license": "MIT",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/abran-labs/ai-auth-kit.git"
  },
  "bin": {
    "ai-auth-kit": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src/account-oauth-browser.ts",
    "src/account-oauth-github.ts",
    "src/account-oauth-openai.ts",
    "src/account-oauth-shared.ts",
    "src/account-oauth.ts",
    "src/atomic-file.ts",
    "src/auth-policy-registry.ts",
    "src/catalog-adapter.ts",
    "src/catalog-cache.ts",
    "src/catalog-http.ts",
    "src/catalog-normalize.ts",
    "src/catalog-refresh.ts",
    "src/catalog-runtime.ts",
    "src/catalog-snapshot.ts",
    "src/catalog-source-schema.ts",
    "src/catalog.ts",
    "src/cli.ts",
    "src/cliproxyapi-archive.ts",
    "src/cliproxyapi-cache.ts",
    "src/cliproxyapi-http.ts",
    "src/cliproxyapi-release.ts",
    "src/cliproxyapi.ts",
    "src/credential-removal.ts",
    "src/external-auth.ts",
    "src/index.ts",
    "src/kit-runtime-auth.ts",
    "src/kit.ts",
    "src/picker.ts",
    "src/safe-dir.ts",
    "src/schema.ts",
    "src/storage.ts",
    "src/types.ts",
    "generated/catalog-provenance.json",
    "generated/catalog-snapshot.json",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "bun test",
    "test:types": "tsc -p tsconfig.test.json --noEmit",
    "audit:dependencies": "bun run scripts/audit-dependencies.ts",
    "qa:minimum-release-age": "bun run scripts/qa-minimum-release-age.ts",
    "qa:git-consumer": "bun run scripts/qa-git-consumer.ts",
    "qa:stale-package": "bun run scripts/qa-stale-package.ts",
    "qa:docs-negative": "bun run scripts/qa-docs-negative.ts",
    "release:build": "bun run scripts/release-build.ts",
    "release:verify": "bun run scripts/release-verify.ts",
    "release:sign-bundle": "bun run scripts/sign-release-bundle.ts",
    "installer-manager:build": "bun run scripts/build-installer-manager.ts",
    "installer:build": "bun run scripts/build-installer.ts",
    "installer:check": "bun run scripts/build-installer.ts --check",
    "qa:release-matrix": "bun run scripts/qa-release-matrix.ts",
    "qa:installer-negative": "bun run scripts/qa-installer-negative.ts",
    "qa:installer-manager-races": "bun run scripts/qa-installer-manager-races.ts",
    "dev": "bun run src/cli.ts"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.0.1",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "ai",
    "auth",
    "cli",
    "llm",
    "model-picker"
  ]
}
